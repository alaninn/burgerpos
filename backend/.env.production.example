# ==========================================
# CONFIGURACIÓN PRODUCCIÓN - DONWEB
# ==========================================

# Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=burgerpos_prod
DB_USER=burgerpos_user
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO

# JWT - Generar clave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_CLAVE_JWT_SUPER_SEGURA_64_CARACTERES

# Puerto de la aplicación
PORT=3001

# URLs del sistema
CLIENT_URL=https://tudominio.com
API_URL=https://tudominio.com/api

# WhatsApp (opcional)
WHATSAPP_SESSION_PATH=./whatsapp-session

# MercadoPago (si lo usas)
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# ARCA/AFIP Facturación Electrónica (si lo usas)
ARCA_ENV=production
ARCA_WSAA_URL=https://wsaa.afip.gov.ar/ws/services/LoginCms
ARCA_WSFE_URL=https://servicios1.afip.gov.ar/wsfev1/service.asmx
ENCRYPTION_KEY=CAMBIAR_CLAVE_ENCRIPTACION_32_CARACTERES

# Entorno
NODE_ENV=production

# Logs
LOG_LEVEL=info

# CORS - Ajustar según tu dominio
CORS_ORIGIN=https://tudominio.com

# Rate Limiting (solicitudes por minuto)
RATE_LIMIT_MAX=100

# Session Secret
SESSION_SECRET=CAMBIAR_SESSION_SECRET_SEGURO
